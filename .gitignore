# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
# Never commit Firebase functions Next.js standalone build output
/functions/.next/
/functions/.next/**/*
/functions/.next/standalone/
/functions/.next/standalone/**/*

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
service-account-key.json

# backups / exports (local artifacts)
/backups/
/backups/**/*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
