{
  "name": "store",
  "version": "0.1.0",
  "private": true,
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 111",
      "safari >= 16.4",
      "ios_saf >= 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "build:firebase": "next build && node scripts/copy-next-build.js",
    "start": "next start",
    "lint": "eslint > lint_output.txt 2>&1",
    "deploy": "npm run build:firebase && firebase deploy --only functions && firebase deploy --only hosting",
    "deploy:hosting": "npm run build:firebase && firebase deploy --only hosting",
    "deploy:functions": "npm run build:firebase && firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only \"firestore:rules,firestore:indexes\"",
    "deploy:storage": "firebase deploy --only storage",
    "deploy:all": "npm run build:firebase && firebase deploy --only \"functions,hosting,firestore:rules,storage\"",
    "deploy:safe": "npm run build:firebase && echo 'Deploying functions...' && firebase deploy --only functions && echo 'Waiting 30 seconds...' && timeout /t 30 /nobreak >nul 2>&1 || sleep 30 && echo 'Deploying hosting...' && firebase deploy --only hosting",
    "create-admin": "node scripts/create-admin.js",
    "taxonomy:gold": "node scripts/replace-fashion-taxonomy.js",
    "taxonomy:fix-translations": "node scripts/fix-taxonomy-translations.js",
    "products:add-arabic": "node scripts/add-arabic-taxonomy-and-products.js",
    "shop:reset": "node scripts/reset-shop-data.js",
    "images:optimize": "node scripts/optimize-existing-images.js",
    "import:demo": "node demo-data/import-demo-data.js",
    "import:database": "node demo-data/import-demo-data.js"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^8.9.2",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.3",
    "critters": "^0.0.23",
    "firebase": "^12.8.0",
    "firebase-admin": "^10.3.0",
    "flutterwave-react-v3": "^1.3.0",
    "framer-motion": "^12.33.0",
    "next": "^16.1.6",
    "nodemailer": "^8.0.1",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-paystack": "^6.0.0",
    "react-phone-number-input": "^3.4.14",
    "react-quill": "^2.0.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.7.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "next-pwa": "^2.0.2",
    "readline-sync": "^1.4.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "axios": "^1.7.9",
    "quill": "2.0.2"
  }
}
